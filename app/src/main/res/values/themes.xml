<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="BaseAppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- General -->
        <item name="colorBackground">#FFFFFF</item>
        <item name="colorShadow">#24000000</item>
        <item name="colorOutline">#1E000000</item>
        <item name="colorTextOverlay">#99000000</item>

        <item name="colorBottomAppBarBackground">#FFFFFF</item>

        <item name="android:navigationBarColor">
            @android:color/transparent
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <!-- Navigation -->
        <item name="colorDrawerBackground">#FFFFFF</item>
        <item name="colorDrawerItemRipple">#59000000</item>
        <item name="colorDrawerItemIconSelected">@color/state_drawer_selected_item_icon_color</item>
        <item name="colorDrawerItemTextSelected">@color/state_drawer_selected_item_color</item>
        <item name="drawableDrawerItemBackground">@drawable/state_drawer_item_background</item>

        <item name="colorNoteText">#000000</item>
        <item name="colorNoteIndicator">#B3000000</item>
        <item name="colorAttachmentIndicator">#89000000</item>
        <item name="colorTaskDone">#80000000</item>
        <item name="colorMarkdownTask">#80000000</item>
        <item name="colorMediaControlsBackground">#CC000000</item>

        <item name="colorTaskSwipe">#CCF44336</item>
        <item name="colorHighlightMask">#1F000000</item>

        <item name="colorNoteDefault">#FFFFFF</item>
        <item name="colorNoteRed">#FFCDD2</item>
        <item name="colorNoteOrange">#FFE0B2</item>
        <item name="colorNoteYellow">#FFF9C4</item>
        <item name="colorNoteGreen">#DCEDC8</item>
        <item name="colorNoteTeal">#B2DFDB</item>
        <item name="colorNoteCyan">#B2EBF2</item>
        <item name="colorNoteBlue">#BBDEFB</item>
        <item name="colorNotePurple">#E1BEE7</item>
        <item name="colorNotePink">#F8BBD0</item>
        <item name="colorNoteBrown">#D7CCC8</item>
        <item name="colorNoteGray">#CFD8DC</item>

        <item name="colorNoteTextHighlight">#96FFFF00</item>

        <item name="popupTheme">@style/Widget.Custom.PopupMenu</item>
        <item name="materialAlertDialogTheme">@style/DialogTheme</item>
    </style>

    <style name="AppTheme" parent="BaseAppTheme">
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <style name="DarkBlack">
        <item name="colorBackground">#000000</item>
        <item name="colorSurface">?attr/colorSurfaceDim</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="colorNoteDefault">?attr/colorSurfaceDim</item>
        <item name="colorDrawerBackground">?attr/colorSurfaceDim</item>
        <item name="colorBottomAppBarBackground">#000000</item>
        <item name="android:navigationBarColor">
            @android:color/transparent
        </item>

    </style>

